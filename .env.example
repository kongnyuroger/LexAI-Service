# Application
PORT=3000

# Database (PostgreSQL with pgvector)
DATABASE_URL="postgresql://lexai:lexai_password@localhost:5432/lexai_db?schema=public"

# JWT Secrets (use long random strings in production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Anthropic / Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Storage
# Path where uploaded documents are stored (local dev); swap for S3/R2 config later
STORAGE_PATH=./uploads

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:8081
