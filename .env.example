# Application
PORT=3000

# Database (PostgreSQL with pgvector)
# Port 5433 avoids conflicts with a local PostgreSQL install on the default 5432
DATABASE_URL="postgresql://lexai:lexai_password@localhost:5433/lexai_db?schema=public"

# JWT Secrets (use long random strings in production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# OpenAI API (GPT-4 for analysis/chat, text-embedding-3-small for RAG)
OPENAI_API_KEY=your_openai_api_key_here

# File Storage
# Path where uploaded documents are stored (local dev); swap for S3/R2 config later
STORAGE_PATH=./uploads

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:8081
